# Copy to .env and fill in.  (.env is gitignored — never commit it.)

# Timezone used for "today"/"tomorrow" and the daily push.
TZ=Europe/Istanbul

# The WhatsApp group the bot posts the daily plan to.
# Leave blank for the first run, send "/jid" in the group, then paste the id
# it replies with here (looks like 1203630xxxxxxxxx@g.us).
GROUP_JID=

# Character that prefixes commands (e.g. /today).
COMMAND_PREFIX=/

# When to post the daily "today" plan (cron, in the TZ above). Default 08:00.
PUSH_CRON=0 8 * * *

# pino log level: silent | info | debug  (use info/debug while setting up)
LOG_LEVEL=silent
